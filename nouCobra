    background-color: #ff29d1;
    background-image: repeating-linear-gradient(45deg, #ff29d1 0px, #ff29d1 10px, #ff57db 10px, #ff57db 20px);
    background-size: 200% 200%;
    
    /* Recorte del texto para que el fondo se vea solo en las letras */
    color: transparent;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    
    /* Bordes y Sombra */
    -webkit-text-stroke: 0;
    filter: drop-shadow(0 0 10px #570044);
    
    /* Animación de movimiento */
    animation: stripe-move-d1 3s linear infinite;
}

/* Keyframes para mover las rayas del texto */
@keyframes stripe-move-d1 { 
    0% { background-position: 0% 0%; } 
    100% { background-position: 200% 200%; } 
}

/* Ajuste para móviles */
@media (max-width: 768px) {
    .text-ultimate { font-size: 59px; }
}

