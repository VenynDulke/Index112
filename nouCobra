    -webkit-backdrop-filter: blur(15px);
    backdrop-filter: blur(15px);
    
    transition: all 1s ease-in-out;
}

/* Clase para ocultarlo con animación (se agrega con JS) */
.entrance-hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(1.1); /* Efecto zoom al desaparecer */
}

/* --- 2. ESTILO DEL TEXTO "ZIVA" --- */
.text-ultimate {
    display: inline-block; 
    font-family: 'Pinyon Script', cursive; /* Requiere importar la fuente */
    font-size: 118px;
    font-weight: 900;
    text-align: center;
    margin: 0;
    line-height: 1.2;
    padding: 0 10px; 
    
